{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "pissbot (console)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}",
      "env": {
        "DiscordToken": "${env:DiscordToken}"
      },
      "args": ["-settings", "${workspaceFolder}/settings.json"]
    },
    {
      "name": "test (current package)",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${fileDirname}"
    }
  ]
}
